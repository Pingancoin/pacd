[Service]
ExecStart=
ExecStart=/usr/local/bin/pacd --network ${PACD_NETWORK} --datadir ${PACD_DATADIR} --rpc --rpclisten ${PACD_RPC_LISTEN} --rpctoken=${PACD_RPC_TOKEN} --p2p --listen ${PACD_P2P_LISTEN} --maxpeers ${PACD_MAX_PEERS} --connect server1.pingancoin.org:9508 --connect server2.pingancoin.org:9508 --connect server3.pingancoin.org:9508
