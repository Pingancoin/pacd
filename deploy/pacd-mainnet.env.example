PACD_NETWORK=mainnet
PACD_DATADIR=/var/lib/pacd
PACD_RPC_LISTEN=127.0.0.1:9509
# Optional. If set, pacd requires: Authorization: Bearer <token>
PACD_RPC_TOKEN=
# Optional. JSONL audit log for RPC submitblock mining submissions.
PACD_SUBMITBLOCK_LOG=/var/log/pingancoin/submitblock.jsonl
PACD_P2P_LISTEN=0.0.0.0:9508
PACD_MAX_PEERS=64
PACD_STRATUM=false
PACD_STRATUM_LISTEN=0.0.0.0:9507
PACD_STRATUM_ADDRESS=
PACD_STRATUM_DIFF=4096
PACD_STRATUM_REFRESH=30s
